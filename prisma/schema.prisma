generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Post {
  id          String   @id @default(uuid())
  slug        String   @unique
  title       String
  description String
  content     String
  category    String
  readTime    String
  createdAt   DateTime @default(now())
}
